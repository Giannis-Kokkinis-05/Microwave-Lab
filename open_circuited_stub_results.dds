defun _DDSobjectRestoreFont_(goId, name, fontName, oldFontName)
{
	set(goId, name, fontName);
	if (get(goId, name) != fontName)
		set(goId, name, oldFontName);
}

defun _DDSobjectRestoreDensityTraceProps_(traceId, numColors, colorOffset, startColor, symbolType)
{
	if (DDSnumTraceTypes > 8) {
		set(traceId, "NumberOfDensityColors", numColors);
		set(traceId, "DensityColorOffset", colorOffset);
		set(traceId, "DensityStartColor", startColor);
		set(traceId, "DensitySymbolType", symbolType);
	}
}

